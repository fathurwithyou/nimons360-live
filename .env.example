# Public host/IP that Android clients can reach (no scheme, no port)
PUBLIC_HOST=localhost

# Coordinator HTTP + WebSocket port
PORT=4000

# MediaMTX endpoints as seen by Android clients.
# RTMP ingest (broadcaster pushes here).
RTMP_PORT=1935
# HLS playback (viewers read here).
HLS_PORT=8888

# Shared secret the Android app sends in `x-api-key` for non-anonymous deploys.
# Leave empty for open/demo mode.
API_KEY=
